format = """
$username\
$hostname\
$directory\
$git_branch\
$git_status\
$nodejs\
$python\
$rust\
$golang\
$docker_context\
$cmd_duration\
$line_break\
$character\
"""

command_timeout = 500
scan_timeout = 30

[character]
success_symbol = "[➜](bold green)"
error_symbol = "[➜](bold red)"

[directory]
truncate_to_repo = true
truncation_length = 3
style = "bold cyan"

[git_branch]
symbol = "🌱 "
style = "bold purple"
truncation_length = 20
format = "[$symbol$branch]($style) "

[git_status]
style = "bold red"
format = '([$all_status$ahead_behind]($style) )'
ahead = "⇡${count}"
behind = "⇣${count}"
diverged = "⇕⇡${ahead_count}⇣${behind_count}"

[nodejs]
symbol = "⬢ "
style = "bold green"
format = "[$symbol($version)]($style) "
detect_files = ["package.json"]
detect_folders = ["node_modules"]

[python]
symbol = "🐍 "
style = "bold blue"
format = "[$symbol($version)]($style) "

[rust]
symbol = "🦀 "
style = "bold red"
format = "[$symbol($version)]($style) "

[golang]
symbol = "🐹 "
style = "bold cyan"
format = "[$symbol($version)]($style) "

[docker_context]
symbol = "🐳 "
style = "bold blue"
format = "[$symbol($context)]($style) "
detect_files = ["docker-compose.yml", "docker-compose.yaml", "Dockerfile"]

[cmd_duration]
min_time = 2000
format = "⏱️  [$duration]($style) "
style = "bold yellow"

[username]
show_always = false
format = "[$user]($style) "
style_user = "bold yellow"

[hostname]
ssh_only = true
format = "[$hostname]($style) "
style = "bold dimmed white"
