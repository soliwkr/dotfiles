#!/usr/bin/env bash
# bootstrap.sh — fresh machine setup
# Usage: bash <(curl -fsSL https://raw.githubusercontent.com/GITHUB_USER/dotfiles/master/.config/bootstrap.sh)
#
# What this does (in order):
#   1. Install yay (AUR helper)
#   2. Install Omarchy (Hyprland DE)
#   3. Install packages from packages.txt
#   4. Clone and apply dotfiles
#   5. Set up SSH key (optional)

set -euo pipefail

DOTFILES_REPO="https://github.com/GITHUB_USER/dotfiles.git"  # ← change this
DOTFILES_DIR="$HOME/.dotfiles"

info()    { echo -e "\033[1;34m==>\033[0m $*"; }
success() { echo -e "\033[1;32m✓\033[0m $*"; }
warn()    { echo -e "\033[1;33m!\033[0m $*"; }

# ── 1. Base deps ────────────────────────────────────────────────────────────
info "Installing base dependencies..."
sudo pacman -Sy --needed --noconfirm git base-devel

# ── 2. yay ──────────────────────────────────────────────────────────────────
if ! command -v yay &>/dev/null; then
  info "Installing yay..."
  git clone https://aur.archlinux.org/yay.git /tmp/yay-bootstrap
  (cd /tmp/yay-bootstrap && makepkg -si --noconfirm)
  rm -rf /tmp/yay-bootstrap
  success "yay installed"
else
  success "yay already present"
fi

# ── 3. Omarchy ──────────────────────────────────────────────────────────────
if [[ ! -d "$HOME/.local/share/omarchy" ]]; then
  info "Installing Omarchy..."
  git clone https://github.com/basecamp/omarchy.git "$HOME/.local/share/omarchy"
  bash "$HOME/.local/share/omarchy/boot.sh"
  success "Omarchy installed"
else
  success "Omarchy already present, updating..."
  git -C "$HOME/.local/share/omarchy" pull
fi

# ── 4. Packages ─────────────────────────────────────────────────────────────
PKGS_FILE="$HOME/.config/packages.txt"
if [[ -f "$PKGS_FILE" ]]; then
  info "Installing packages from packages.txt..."
  # Filter out packages already installed
  mapfile -t pkgs < "$PKGS_FILE"
  to_install=()
  for pkg in "${pkgs[@]}"; do
    pacman -Qi "$pkg" &>/dev/null || to_install+=("$pkg")
  done
  if [[ ${#to_install[@]} -gt 0 ]]; then
    yay -S --needed --noconfirm "${to_install[@]}" || warn "Some packages failed — check manually"
  fi
  success "Packages installed"
fi

# ── 5. Dotfiles ─────────────────────────────────────────────────────────────
dotfiles() { /usr/bin/git --git-dir="$DOTFILES_DIR/" --work-tree="$HOME" "$@"; }

if [[ ! -d "$DOTFILES_DIR" ]]; then
  info "Cloning dotfiles..."
  git clone --bare "$DOTFILES_REPO" "$DOTFILES_DIR"
  dotfiles config --local status.showUntrackedFiles no

  # Back up any conflicting files before checkout
  if ! dotfiles checkout 2>/dev/null; then
    warn "Conflicts found — backing up to ~/.dotfiles-backup/"
    mkdir -p "$HOME/.dotfiles-backup"
    dotfiles checkout 2>&1 \
      | grep -E "^\s+\." \
      | awk '{print $1}' \
      | xargs -I{} sh -c 'mkdir -p "$HOME/.dotfiles-backup/$(dirname {})" && mv "$HOME/{}" "$HOME/.dotfiles-backup/{}"'
    dotfiles checkout
  fi
  success "Dotfiles applied"
else
  info "Dotfiles repo exists, pulling latest..."
  dotfiles pull
  success "Dotfiles updated"
fi

# ── 6. SSH key ──────────────────────────────────────────────────────────────
if [[ ! -f "$HOME/.ssh/id_ed25519" ]]; then
  info "No SSH key found. Generate one? [y/N]"
  read -r answer
  if [[ "${answer,,}" == "y" ]]; then
    read -rp "Email for SSH key [soliwkr@gmail.com]: " ssh_email
    ssh_email="${ssh_email:-soliwkr@gmail.com}"
    ssh-keygen -t ed25519 -C "$ssh_email" -f "$HOME/.ssh/id_ed25519"
    eval "$(ssh-agent -s)"
    ssh-add "$HOME/.ssh/id_ed25519"
    echo ""
    warn "Your public key (add this to GitHub → Settings → SSH keys):"
    cat "$HOME/.ssh/id_ed25519.pub"
    echo ""
    warn "Press enter after adding the key to GitHub to switch dotfiles remote to SSH..."
    read -r
    dotfiles remote set-url origin "git@github.com:GITHUB_USER/dotfiles.git"
    success "Remote switched to SSH"
  fi
else
  success "SSH key already exists"
fi

echo ""
success "Bootstrap complete! Log out and back in (or reboot) to start Omarchy."
