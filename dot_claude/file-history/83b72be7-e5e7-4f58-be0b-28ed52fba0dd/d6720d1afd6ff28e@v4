# See https://wiki.hyprland.org/Configuring/Monitors/
# Format: monitor=name,resolution,position,scale

# Dell Precision 5550 — 4K touch (3840x2400@60Hz)
# Scale 2 = effective 1920x1200
env = GDK_SCALE,2
monitor=eDP-1,3840x2400@60,320x1440,2

# ViewSonic VX3276-QHD — 2560x1440@75Hz, sopra il principale (centrato)
monitor=DP-2,2560x1440@74.93,0x0,1

# Fallback for any unrecognised monitor
monitor=,preferred,auto,1
